{
  "name": "ide-bridge",
  "version": "0.1.0-alpha.0",
  "description": "Cross-IDE context bridge over MCP — save a checkpoint from one agentic IDE, resume in another with no lost context",
  "type": "module",
  "license": "MIT",
  "author": "Xsidz <siddhesh.kabraa@gmail.com> (https://github.com/Xsidz)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Xsidz/ide-bridge.git"
  },
  "bugs": {
    "url": "https://github.com/Xsidz/ide-bridge/issues"
  },
  "homepage": "https://www.ide-bridge.dev",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ide",
    "claude-code",
    "cursor",
    "kiro",
    "antigravity",
    "agent",
    "context",
    "handoff",
    "portable-context-bundle",
    "pcb"
  ],
  "main": "./dist/daemon.js",
  "types": "./dist/daemon.d.ts",
  "exports": {
    ".": {
      "types": "./dist/daemon.d.ts",
      "import": "./dist/daemon.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "bin": {
    "ide-bridge": "./dist/index.js"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "prebuild": "node -e \"require('node:fs').cpSync('src/priming/templates','dist/priming/templates',{recursive:true})\"",
    "build": "tsc && chmod +x dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "commander": "^14.0.3",
    "fastify": "^5.8.5",
    "pino": "^10.3.1",
    "simple-git": "^3.36.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
